                      "parameters":  {
                                         "jsCode":  "const leadData = $(\u0027Montar Template Teste\u0027).item.json;\nconst responseData = $input.item.json || {};\nconst inputError = $input.item.error || null;\n\nconst providerMessageId = responseData?.key?.id || \u0027\u0027;\nconst providerStatus = responseData.status || (providerMessageId ? \u0027PENDING\u0027 : \u0027ERROR\u0027);\n\nconst providerErrorMessage =\n  (inputError \u0026\u0026 inputError.message)\n  || responseData.message\n  || responseData.error\n  || \u0027\u0027;\n\nconst hasProviderError = !!providerErrorMessage \u0026\u0026 !providerMessageId;\nconst envioOk = !!providerMessageId \u0026\u0026 !hasProviderError;\n\nreturn [{\n  json: {\n    ...leadData,\n    envio_ok: envioOk,\n    envio_status: envioOk ? \u0027enviado\u0027 : \u0027erro\u0027,\n    envio_em: new Date().toISOString(),\n    provider_message_id: providerMessageId,\n    provider_status: providerStatus,\n    erro_envio: envioOk ? \u0027\u0027 : (providerErrorMessage || \u0027Erro desconhecido no envio Evolution\u0027)\n  }\n}];"
