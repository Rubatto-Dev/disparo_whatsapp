                  {
                      "id":  "node-template",
                      "name":  "Montar Template Teste",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1620,
                                       420
                                   ],
                      "parameters":  {
                                         "jsCode":  "const normalizePhone = (value) =\u003e {\n  const raw = String(value || \u0027\u0027).trim();\n  const digits = raw.replace(/\\D/g, \u0027\u0027);\n  if (!digits) return \u0027\u0027;\n\n  const normalized = digits.startsWith(\u002700\u0027) ? digits.slice(2) : digits;\n  const hasExplicitCountryCode = raw.startsWith(\u0027+\u0027) || digits.startsWith(\u002700\u0027) || (digits.startsWith(\u002755\u0027) \u0026\u0026 digits.length \u003e= 12);\n\n  if (hasExplicitCountryCode) {\n    return normalized.length \u003e= 11 \u0026\u0026 normalized.length \u003c= 15 ? normalized : \u0027\u0027;\n  }\n\n  if (normalized.length === 10 || normalized.length === 11) {\n    return `55${normalized}`;\n  }\n\n  return normalized.length \u003e= 12 \u0026\u0026 normalized.length \u003c= 15 ? normalized : \u0027\u0027;\n};\n\nconst nomeCompletoRaw = String($json.nome || \u0027\u0027).trim();\nconst primeiroNomeRaw = String($json.primeiro_nome || \u0027\u0027).trim();\nconst primeiroNome = primeiroNomeRaw || (nomeCompletoRaw ? nomeCompletoRaw.split(\u0027 \u0027)[0] : \u0027\u0027);\nconst nome = primeiroNome \u0026\u0026 primeiroNome.toLowerCase() !== \u0027cliente\u0027 ? primeiroNome : \u0027\u0027;\nconst categoria = String($json.categoria || \u0027Cliente\u0027).trim() || \u0027Cliente\u0027;\nconst foco = String($env.CAMPAIGN_TEMPLATE_FOCUS || \u0027oportunidades imobiliarias\u0027).trim();\nconst campaignId = String($env.CAMPAIGN_ID || `campanha_${new Date().toISOString().slice(0, 10)}`);\nconst templateMode = String($env.CAMPAIGN_TEMPLATE_MODE || \u0027normal\u0027).toLowerCase();\n\nconst originalPhone = String($json.phone || \u0027\u0027).replace(/\\D/g, \u0027\u0027);\nconst forcePhoneRaw = String($env.CAMPAIGN_FORCE_PHONE || \u0027\u0027).trim();\nconst forcedPhone = normalizePhone(forcePhoneRaw);\nconst usarNumeroTeste = !!forcedPhone;\nconst phoneDestino = usarNumeroTeste ? forcedPhone : originalPhone;\nconst alertaNumeroTeste = forcePhoneRaw \u0026\u0026 !usarNumeroTeste\n  ? \u0027CAMPAIGN_FORCE_PHONE invalido. Seguindo telefone original.\u0027\n  : \u0027\u0027;\n\nconst telefonePlanilha = String($json.telefone_csv || originalPhone || \u0027\u0027).replace(/\\D/g, \u0027\u0027);\nconst grupoOrigemBruto = String($json.grupos_origem || \u0027\u0027).trim();\nconst grupoOrigem = grupoOrigemBruto\n  .replace(/excel results/ig, \u0027\u0027)\n  .replace(/\\s*\\|\\s*/g, \u0027 | \u0027)\n  .replace(/\\s+/g, \u0027 \u0027)\n  .trim();\nconst grupoPrincipal = grupoOrigem ? grupoOrigem.split(\u0027|\u0027)[0].trim() : \u0027\u0027;\nconst categoriaInfo = categoria \u0026\u0026 categoria.toLowerCase() !== \u0027cliente\u0027 ? categoria : \u0027\u0027;\n\nconst hashSeed = `${originalPhone}|${campaignId}|${grupoPrincipal}|${categoria}|${nome}`;\nlet hash = 0;\nfor (const ch of hashSeed) {\n  hash = ((hash \u003c\u003c 5) - hash + ch.charCodeAt(0)) \u003e\u003e\u003e 0;\n}\n\nconst pick = (arr, salt = 0) =\u003e {\n  if (!arr.length) return \u0027\u0027;\n  const index = (hash + salt + Math.floor(Math.random() * 997)) % arr.length;\n  return arr[index];\n};\n\nconst maybe = (value, chance = 0.5) =\u003e (Math.random() \u003c chance ? value : \u0027\u0027);\n\nlet mensagemFinal = \u0027\u0027;\nlet templateName = `T${(hash % 7) + 1}`;\n\nif (templateMode === \u0027debug\u0027) {\n  templateName = \u0027DEBUG\u0027;\n  mensagemFinal = [\n    \u0027TESTE TECNICO - DADOS DA PLANILHA\u0027,\n    `contato_id: ${$json.contato_id || \u0027-\u0027}`,\n    `nome: ${nome || \u0027-\u0027}`,\n    `telefone_planilha: +${telefonePlanilha || \u0027-\u0027}`,\n    `telefone_destino: +${phoneDestino || \u0027-\u0027}`,\n    `categoria: ${categoria}`,\n    `grupo_origem: ${grupoPrincipal || \u0027-\u0027}`,\n    `arquivo_origem: ${String($json.origem_arquivo || \u0027-\u0027)}`,\n    `campaign_id: ${campaignId}`\n  ].join(\u0027\\n\u0027);\n}\n\nif (templateMode === \u0027hogar\u0027) {\n  const aberturasComNome = [\n    `Oi ${nome}, tudo bem? Aqui e da equipe Hogar Imoveis.`,\n    `Ola ${nome}, aqui e da equipe Hogar Imoveis.`,\n    `${nome}, tudo certo? Falo da equipe Hogar Imoveis.`,\n    `${nome}, prazer falar com voce. Equipe Hogar Imoveis aqui.`\n  ];\n\n  const aberturasSemNome = [\n    \u0027Oi, tudo bem? Aqui e da equipe Hogar Imoveis.\u0027,\n    \u0027Ola! Aqui e da equipe Hogar Imoveis.\u0027,\n    \u0027Tudo certo? Falo da equipe Hogar Imoveis.\u0027,\n    \u0027Prazer falar com voce, aqui e da equipe Hogar Imoveis.\u0027\n  ];\n\n  const contextos = [\n    `Mapeamos uma oportunidade de ${foco} com potencial de valorizacao em Goiania.`,\n    `Temos uma oportunidade de ${foco} alinhada para analise rapida.`,\n    `Selecionamos uma opcao de ${foco} com boa relacao risco x retorno.`,\n    `Encontramos uma oportunidade de ${foco} com condicoes competitivas no momento.`\n  ];\n\n  if (grupoPrincipal) {\n    contextos.push(`O contato veio do grupo ${grupoPrincipal}, por isso separei uma sugestao objetiva.`);\n  }\n\n  if (categoriaInfo) {\n    contextos.push(`A proposta foi montada para o perfil ${categoriaInfo}.`);\n  }\n\n  const provas = [\n    \u0027Sem compromisso: se nao fizer sentido, encerramos por aqui.\u0027,\n    \u0027A analise e objetiva, sem pressao comercial.\u0027,\n    \u0027E uma abordagem consultiva, com foco no seu momento.\u0027,\n    \u0027A ideia e te poupar tempo com opcoes filtradas.\u0027\n  ];\n\n  const ctas = [\n    \u0027Posso te enviar agora um resumo curto com faixa de valor e proximos passos?\u0027,\n    \u0027Se fizer sentido, te mando em seguida 2 opcoes enxutas para avaliacao.\u0027,\n    \u0027Quer que eu te encaminhe os detalhes de forma direta, por aqui mesmo?\u0027,\n    \u0027Posso compartilhar agora uma visao rapida das melhores opcoes da semana?\u0027,\n    \u0027Prefere que eu envie primeiro um resumo de 3 linhas e depois detalhamos?\u0027\n  ];\n\n  const fechamentos = [\n    \u0027Se preferir, posso retornar em outro horario.\u0027,\n    \u0027Se nao quiser receber esse tipo de contato, me avise que removo da lista.\u0027,\n    \u0027Caso nao seja o momento, eu paro por aqui sem problema.\u0027,\n    \u0027Se quiser, adapto o perfil antes de enviar qualquer opcao.\u0027\n  ];\n\n  const assinaturas = [\n    \u0027Equipe Hogar Imoveis\u0027,\n    \u0027Time Comercial Hogar Imoveis\u0027,\n    \u0027Consultoria Hogar Imoveis\u0027\n  ];\n\n  const abertura = nome ? pick(aberturasComNome, 11) : pick(aberturasSemNome, 13);\n  const contexto = pick(contextos, 17);\n  const prova = pick(provas, 19);\n  const cta = pick(ctas, 23);\n  const fechamento = maybe(pick(fechamentos, 29), 0.55);\n  const assinatura = pick(assinaturas, 31);\n\n  mensagemFinal = [abertura, contexto, prova, cta, fechamento, `(${assinatura})`]\n    .filter(Boolean)\n    .join(\u0027 \u0027);\n\n  templateName = `HOGAR_V${((hash + Math.floor(Math.random() * 1000)) % 12) + 1}`;\n}\n\nif (templateMode !== \u0027hogar\u0027 \u0026\u0026 templateMode !== \u0027debug\u0027) {\n  const basicos = [\n    nome\n      ? `Oi ${nome}, separei uma oportunidade de ${foco}. Quer que eu te envie agora?`\n      : `Oi, separei uma oportunidade de ${foco}. Quer que eu te envie agora?`,\n    nome\n      ? `${nome}, identifiquei uma oportunidade alinhada ao seu perfil. Posso compartilhar em seguida?`\n      : \u0027Identifiquei uma oportunidade alinhada ao seu perfil. Posso compartilhar em seguida?\u0027,\n    nome\n      ? `${nome}, tenho uma opcao com bom potencial no mercado imobiliario. Posso te mandar um resumo?`\n      : \u0027Tenho uma opcao com bom potencial no mercado imobiliario. Posso te mandar um resumo?\u0027\n  ];\n\n  mensagemFinal = pick(basicos, 41);\n}\n\nreturn [{\n  json: {\n    ...$json,\n    campaignId,\n    template_id: templateName,\n    mensagem_final: mensagemFinal,\n    categoria,\n    phone_original: originalPhone,\n    phone_destino: phoneDestino,\n    phone: phoneDestino,\n    modo_teste_numero: usarNumeroTeste,\n    alerta_numero_teste: alertaNumeroTeste,\n    template_mode: templateMode\n  }\n}];"
                                     }
                  },
