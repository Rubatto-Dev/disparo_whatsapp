                  {
                      "id":  "node-filter",
                      "name":  "Filtrar Contatos Validos",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       900,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const maxContacts = Number($env.CAMPAIGN_MAX_CONTACTS || 200);\nconst seen = new Set();\nconst namedContacts = [];\nconst unnamedContacts = [];\n\nconst normalizePhone = (value) =\u003e {\n  const raw = String(value || \u0027\u0027).trim();\n  const digits = raw.replace(/\\D/g, \u0027\u0027);\n  if (!digits) return \u0027\u0027;\n\n  const normalized = digits.startsWith(\u002700\u0027) ? digits.slice(2) : digits;\n  const hasExplicitCountryCode = raw.startsWith(\u0027+\u0027) || digits.startsWith(\u002700\u0027) || (digits.startsWith(\u002755\u0027) \u0026\u0026 digits.length \u003e= 12);\n\n  if (hasExplicitCountryCode) {\n    return normalized.length \u003e= 11 \u0026\u0026 normalized.length \u003c= 15 ? normalized : \u0027\u0027;\n  }\n\n  if (normalized.length === 10 || normalized.length === 11) {\n    return `55${normalized}`;\n  }\n\n  return normalized.length \u003e= 12 \u0026\u0026 normalized.length \u003c= 15 ? normalized : \u0027\u0027;\n};\n\nconst cleanName = (value) =\u003e String(value || \u0027\u0027)\n  .replace(/\\s+/g, \u0027 \u0027)\n  .replace(/[^\\p{L}\\p{N}\\s\u0027.-]/gu, \u0027\u0027)\n  .trim();\n\nconst chooseName = (row) =\u003e {\n  const candidates = [\n    row.nome,\n    row.name,\n    row.first_name,\n    row.nome_contato,\n    row.contato,\n    row.contact_name\n  ];\n\n  for (const candidate of candidates) {\n    const clean = cleanName(candidate);\n    if (!clean) continue;\n    const lower = clean.toLowerCase();\n    if ([\u0027cliente\u0027, \u0027contato\u0027, \u0027na\u0027, \u0027n/a\u0027, \u0027unknown\u0027].includes(lower)) continue;\n    return clean;\n  }\n\n  return \u0027\u0027;\n};\n\nfor (const item of $input.all()) {\n  const row = item.json || {};\n  const phone = normalizePhone(row.whatsapp || row.telefone || row.celular || row.phone || row.numero);\n  if (!phone) continue;\n  if (seen.has(phone)) continue;\n  seen.add(phone);\n\n  const nome = chooseName(row);\n  const primeiroNome = nome ? nome.split(\u0027 \u0027)[0] : \u0027\u0027;\n  const categoria = String(row.categoria || row.tipo || \u0027Cliente\u0027).trim() || \u0027Cliente\u0027;\n  const telefoneCsv = String(row.telefone || \u0027\u0027).replace(/\\D/g, \u0027\u0027);\n  const whatsappCsv = String(row.whatsapp || \u0027\u0027).replace(/\\D/g, \u0027\u0027);\n  const gruposOrigem = String(row.grupos_origem || row.grupo_origem || \u0027\u0027).trim();\n  const origemArquivo = String(row.arquivos_origem || row.origem_arquivo || \u0027\u0027).trim();\n\n  const normalized = {\n    json: {\n      nome,\n      primeiro_nome: primeiroNome,\n      contato_tag: primeiroNome || `contato ${phone.slice(-4)}`,\n      phone,\n      categoria,\n      telefone_csv: telefoneCsv,\n      whatsapp_csv: whatsappCsv,\n      origem_arquivo: origemArquivo,\n      grupos_origem: gruposOrigem,\n      eh_contato_salvo: String(row.eh_contato_salvo ?? \u0027\u0027),\n      eh_negocio: String(row.eh_negocio ?? \u0027\u0027),\n      eh_admin: String(row.eh_admin ?? \u0027\u0027),\n      contato_id: `${phone}-${origemArquivo || \u0027local\u0027}`\n    }\n  };\n\n  if (nome) {\n    namedContacts.push(normalized);\n  } else {\n    unnamedContacts.push(normalized);\n  }\n}\n\nconst out = [...namedContacts, ...unnamedContacts].slice(0, maxContacts);\n\nif (!out.length) {\n  return [{\n    json: {\n      _campaignDone: true,\n      message: \u0027Nenhum contato valido encontrado na planilha local.\u0027\n    }\n  }];\n}\n\nreturn out;"
                                     }
