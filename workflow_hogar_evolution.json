            "telefone": "={{ $json.telefone }}",
            "nome": "={{ $json.nome }}",
            "segmento": "={{ $json.segmento }}",
            "lead_id": "={{ $json.lead_id }}",
            "campanha_id": "={{ $json.campanha_id }}",
            "imovel_id": "={{ $json.imovel_id }}",
            "status": "erro",
            "erro_envio": "={{ $json.erro_envio }}",
            "provider_status": "={{ $json.provider_status }}",
            "mensagem": "={{ $json.mensagem_final }}"
          },
          "schema": []
        },
        "options": {}
      },
      "continueOnFail": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "SUBSTITUIR_PELO_ID_DA_CREDENCIAL",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "id": "node-wait",
      "name": "Espera Anti-RateLimit",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [3120, 300],
      "parameters": {
        "resume": "timeInterval",
        "unit": "seconds",
        "amount": 3
      }
    }
  ],

