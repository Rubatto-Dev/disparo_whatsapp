            "provider_message_id": "={{ $json.provider_message_id }}",
            "provider_status": "={{ $json.provider_status }}",
            "mensagem": "={{ $json.mensagem_final }}"
          },
          "schema": []
        },
        "options": {}
      },
      "continueOnFail": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "SUBSTITUIR_PELO_ID_DA_CREDENCIAL",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "id": "node-log-error",
      "name": "Registrar Log Erro (Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [2880, 420],
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "={{ $env.LEADS_SHEET_ID }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "={{ $env.LEADS_ERROR_SHEET_NAME || 'envios_erros' }}",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
