# Core n8n
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_RESTRICT_FILE_ACCESS_TO=/data/saida;/home/node/.n8n-files
N8N_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback

# CSV local
CONTACTS_CSV_PATH=/home/node/.n8n-files/planilha_mestre_segmentada_nobom.csv

# Google OAuth para credencial Google Sheets no n8n
GOOGLE_OAUTH_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=seu-client-secret

# Google OAuth Desktop para scripts locais
GOOGLE_DESKTOP_CLIENT_ID=seu-desktop-client-id.apps.googleusercontent.com
GOOGLE_DESKTOP_CLIENT_SECRET=seu-desktop-client-secret

# Google Sheets
LEADS_SHEET_ID=id-da-planilha-entre-/d/-e-/edit
LEADS_SHEET_NAME=Leads
LEADS_LOG_SHEET_NAME=envios_log
LEADS_ERROR_SHEET_NAME=envios_erros

# OpenAI (somente no workflow com IA)
OPENAI_API_KEY=sk-...

# Evolution API
EVOLUTION_BASE_URL=http://evolution_api:8080
EVOLUTION_API_KEY=hogar_evolution_key_2026
EVOLUTION_INSTANCE=nome-da-instancia-no-evolution
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome
CONFIG_SESSION_PHONE_VERSION=2.3000.1034722109
QRCODE_LIMIT=30
QRCODE_COLOR=#175197

# Campanha - seguranca
CAMPAIGN_SEND_LOCK=true
CAMPAIGN_DRY_RUN=true
CAMPAIGN_FORCE_PHONE=
CAMPAIGN_ALERT_PHONE=
CAMPAIGN_KILL_SWITCH_ERRORS=5

# Campanha - janela e volume
CAMPAIGN_ID=campanha_teste
CAMPAIGN_MAX_CONTACTS=20
CAMPAIGN_START_HOUR=9
CAMPAIGN_END_HOUR=17
CAMPAIGN_TIMEZONE=America/Sao_Paulo
CAMPAIGN_RAMP_ENABLED=true
CAMPAIGN_RAMP_DAY=1
# Numero novo: perfil conservador. Aumente CAMPAIGN_RAMP_DAY a cada dia.
# Dia 1-2: 20/dia | Dia 3-4: 30/dia | Dia 5-7: 50/dia | Semana 2+: 80-120/dia
CAMPAIGN_RAMP_PROFILE=20|20|30|30|50|80|100|120

# Campanha - audiencia/filtros
CAMPAIGN_AUDIENCE=parceiros
CAMPAIGN_GROUP_FILTER=
CAMPAIGN_OWNER_FILTER=
CAMPAIGN_SKIP_ADMINS=true
CAMPAIGN_ALLOW_NON_BR=false
CAMPAIGN_VALIDATION_MODE=name_group
CAMPAIGN_TARGET_NAME=
CAMPAIGN_TARGET_GROUP=
CAMPAIGN_OWNER_HINTS_RHUAN=
CAMPAIGN_OWNER_HINTS_HUGO=

# Campanha - status em CSV
CAMPAIGN_STATUS_COLUMN=status_campanha
CAMPAIGN_STATUS_ID_COLUMN=campanha_status_id
CAMPAIGN_STATUS_SCOPE=campaign
CAMPAIGN_STATUS_FILTER=nao_enviado

# Campanha - mensagem
CAMPAIGN_TEMPLATE_MODE=hogar
CAMPAIGN_TEMPLATE_FOCUS=imoveis de luxo
CAMPAIGN_USE_AT_MENTION=false
CAMPAIGN_GREETING_STRATEGY=rotativo
CAMPAIGN_TICKET_DEFAULT=premium

# Campanha - anti-ban (cadencia)
CAMPAIGN_DELAY_MIN_SECONDS=35
CAMPAIGN_DELAY_MAX_SECONDS=65
CAMPAIGN_DELAY_PROFILE=35-65|40-75|50-80
CAMPAIGN_DELAY_SWITCH_EVERY=6
CAMPAIGN_LONG_BREAK_ENABLED=true
CAMPAIGN_LONG_BREAK_EVERY_MIN=15
CAMPAIGN_LONG_BREAK_EVERY_MAX=20
CAMPAIGN_LONG_BREAK_MIN_SECONDS=480
CAMPAIGN_LONG_BREAK_MAX_SECONDS=900

# Campanha - simulacao de digitando
CAMPAIGN_TYPING_ENABLED=true
CAMPAIGN_TYPING_PRESENCE=composing
CAMPAIGN_TYPING_MIN_MS=1200
CAMPAIGN_TYPING_MAX_MS=4200
CAMPAIGN_TYPING_MS_PER_CHAR=28

# Inbound - webhook/classificacao/deduplicacao
INBOUND_WEBHOOK_PATH=evolution/inbound
INBOUND_WEBHOOK_SECRET=
INBOUND_DEDUPE_TTL_SECONDS=172800
INBOUND_DEDUPE_TEXT_WINDOW_SECONDS=600
INBOUND_DEDUPE_MAX_KEYS=50000
INBOUND_BLOCK_ON_NEGATIVE=true
INBOUND_BLOCK_ON_POSITIVE=false
INBOUND_LOG_SHEET_NAME=inbound_log
INBOUND_ORPHAN_SHEET_NAME=inbound_orfaos
