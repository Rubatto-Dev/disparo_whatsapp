# =========================================================
# .env.example - Disparo WhatsApp (Hogar)
# =========================================================
# Como usar:
# 1) Copie este arquivo para .env
# 2) Preencha os campos obrigatorios
# 3) Suba os containers com: docker compose up -d
# 4) Rode dry-run primeiro e depois habilite envio real
#
# Seguranca:
# - Nao versionar o arquivo .env real
# - Nao versionar planilhas/CSV com dados de clientes
# =========================================================

# ---------------------------------------------------------
# Google OAuth (n8n) - usado apenas no workflow Google Sheets
# ---------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=seu-client-secret
N8N_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback

# ---------------------------------------------------------
# Google OAuth Desktop (scripts Python locais)
# ---------------------------------------------------------
GOOGLE_DESKTOP_CLIENT_ID=seu-desktop-client-id.apps.googleusercontent.com
GOOGLE_DESKTOP_CLIENT_SECRET=seu-desktop-client-secret

# ---------------------------------------------------------
# Google Sheets
# ---------------------------------------------------------
LEADS_SHEET_ID=id-da-planilha-entre-/d/-e-/edit
LEADS_SHEET_NAME=Leads
LEADS_LOG_SHEET_NAME=envios_log
LEADS_ERROR_SHEET_NAME=envios_erros

# ---------------------------------------------------------
# OpenAI (necessario apenas para workflow com IA)
# ---------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------
# Evolution API
# ---------------------------------------------------------
EVOLUTION_API_KEY=hogar_evolution_key_2026
EVOLUTION_INSTANCE=nome-da-instancia-no-evolution
CONFIG_SESSION_PHONE_CLIENT=Evolution API
CONFIG_SESSION_PHONE_NAME=Chrome
CONFIG_SESSION_PHONE_VERSION=2.3000.1034722109
QRCODE_LIMIT=30

# ---------------------------------------------------------
# n8n / acesso a arquivos locais para CSV
# ---------------------------------------------------------
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_RESTRICT_FILE_ACCESS_TO=/data/saida;/home/node/.n8n-files

# Caminho do CSV dentro do container n8n
CONTACTS_CSV_PATH=/data/saida/planilha_mestre_segmentada.csv

# ---------------------------------------------------------
# Campanha - Modo de execucao
# ---------------------------------------------------------
# true  = simula, nao envia mensagem real
# false = envia mensagem real
CAMPAIGN_DRY_RUN=true

# Identificacao da campanha nos logs/status
CAMPAIGN_ID=campanha_teste_20260310

# Tema do template
CAMPAIGN_TEMPLATE_FOCUS=imoveis de luxo
CAMPAIGN_TEMPLATE_MODE=hogar

# Numero forcado para homologacao (deixe vazio em producao)
# Exemplo: 5562999999999
CAMPAIGN_FORCE_PHONE=

# Quantidade maxima por execucao (sera combinada com a rampa)
CAMPAIGN_MAX_CONTACTS=200

# ---------------------------------------------------------
# Campanha - Filtro de publico e segmentacao
# ---------------------------------------------------------
# clientes   = envia apenas para clientes
# parceiros  = envia apenas para corretores/parceiros
# todos      = envia para toda a base valida
CAMPAIGN_AUDIENCE=clientes

CAMPAIGN_GROUP_FILTER=
CAMPAIGN_TARGET_NAME=
CAMPAIGN_TARGET_GROUP=
CAMPAIGN_VALIDATION_MODE=name_group
CAMPAIGN_OWNER_FILTER=

CAMPAIGN_SKIP_ADMINS=true
CAMPAIGN_ALLOW_NON_BR=false
CAMPAIGN_OWNER_HINTS_RHUAN=RHUAN
CAMPAIGN_OWNER_HINTS_HUGO=HUGO
CAMPAIGN_TICKET_DEFAULT=nao_informado

# false = nao usa "@nome" no texto (recomendado)
# true  = tenta incluir "@nome" no texto
CAMPAIGN_USE_AT_MENTION=false

# ---------------------------------------------------------
# Campanha - Status por campanha (persistencia no CSV)
# ---------------------------------------------------------
CAMPAIGN_STATUS_COLUMN=status_campanha
CAMPAIGN_STATUS_ID_COLUMN=campanha_status_id
# campaign = respeita o status por campanha_id | all = considera status global
CAMPAIGN_STATUS_SCOPE=campaign
# Valores aceitos: nao_enviado, enviando, enviado
CAMPAIGN_STATUS_FILTER=nao_enviado

# ---------------------------------------------------------
# Campanha - Anti-ban (saudacao, delays e pausas longas)
# ---------------------------------------------------------
CAMPAIGN_GREETING_STRATEGY=rotativo
CAMPAIGN_DELAY_PROFILE=20-35|40-70|75-120
CAMPAIGN_DELAY_SWITCH_EVERY=8
CAMPAIGN_DELAY_MIN_SECONDS=25
CAMPAIGN_DELAY_MAX_SECONDS=45

# Pausa longa aleatoria para quebrar padrao
CAMPAIGN_LONG_BREAK_ENABLED=true
CAMPAIGN_LONG_BREAK_EVERY_MIN=20
CAMPAIGN_LONG_BREAK_EVERY_MAX=30
CAMPAIGN_LONG_BREAK_MIN_SECONDS=300
CAMPAIGN_LONG_BREAK_MAX_SECONDS=720

# Mata execucao apos X erros consecutivos e envia alerta
CAMPAIGN_KILL_SWITCH_ERRORS=3
CAMPAIGN_ALERT_PHONE=5562990000000

# ---------------------------------------------------------
# Campanha - Rampa de volume (dia a dia)
# ---------------------------------------------------------
# true  = respeita rampa
# false = usa apenas CAMPAIGN_MAX_CONTACTS
CAMPAIGN_RAMP_ENABLED=true
# Exemplo: dia1=40, dia2=80, dia3=150, dia4=250...
CAMPAIGN_RAMP_PROFILE=40|80|150|250|400|600
CAMPAIGN_RAMP_DAY=1

# ---------------------------------------------------------
# Campanha - Janela de horario
# ---------------------------------------------------------
CAMPAIGN_START_HOUR=8
CAMPAIGN_END_HOUR=20
CAMPAIGN_TIMEZONE=America/Sao_Paulo
